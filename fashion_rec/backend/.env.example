# Copy to .env and adjust. Do not commit real secrets.

# --- LocateAnything bbox（Studio 意图裁剪）---
# 推理服务在 GPU 机 kdsvgm5（Tailscale 100.73.75.78）；本机 dev 为 100.127.212.44
# LOCATEANYTHING_ENABLED=true
# LOCATEANYTHING_BASE_URL=http://100.73.75.78:8000
# 本地/ChatKit 图片：后端读字节后 POST /v1/locate_bytes（GPU 需部署最新 locateanything-service/run_model.py）
# 公网 R2 图仍走 /v1/locate?image_url=...
# 可选：本机 backend 用 localhost 拉图时改写成 tailnet IP（无 locate_bytes 时的回退）
# LOCATEANYTHING_TAILNET_DEV_HOST=100.127.212.44
# 若在本机也跑 LocateAnything（需 NVIDIA）：LOCATEANYTHING_BASE_URL=http://127.0.0.1:8000
# LOCATEANYTHING_TIMEOUT_SECONDS=60
# LOCATEANYTHING_MAX_IMAGE_DIM=1280
# LOCATEANYTHING_MAX_CONCURRENCY=3
# ChatKit（有附件时也会选 reasoning，建议 routing=fast 且两项都用 non-reasoning）：
# CHATKIT_XAI_ROUTING=fast
# CHATKIT_XAI_MODEL_FAST=grok-4.20-0309-non-reasoning
# CHATKIT_XAI_MODEL_REASONING=grok-4.20-0309-non-reasoning
# GARMENT_ASSESS_GROK_MODEL=grok-4-1-fast-non-reasoning
# Fly 入网（Reusable key: https://login.tailscale.com/admin/settings/keys）
# TS_AUTHKEY=tskey-auth-...

# --- ChatKit → xAI (Grok) ---
# XAI_API_KEY=...

# 试衣 / 意图裁剪 Grok 评估与多图规划（默认 grok-4-1-fast-reasoning）
# GARMENT_ASSESS_GROK_MODEL=grok-4-1-fast-reasoning

# 穿搭生成在选 Grok 后端时（默认 grok-imagine-image）
# OUTFIT_GROK_MODEL=grok-imagine-image

# 必须走代理时（推荐）：Windows 上 v2rayN「自动系统代理」往往不会传给 uvicorn，请二选一：
# 1) 本机 mixed 端口（v2rayN 状态栏「mixed:10808」）— 最省事：
CHATKIT_XAI_LOCAL_PROXY_PORT=10808
# 2) 或写完整 URL（Clash HTTP 端口多为 7890 等）：
# CHATKIT_XAI_PROXY=http://127.0.0.1:10808
# SOCKS5 需安装 socksio：uv add socksio
# CHATKIT_XAI_PROXY=socks5://127.0.0.1:10808

# v2ray 全局模式时，请在客户端「绕过 / 直连」中加入 127.0.0.1、localhost，
# 避免本进程访问本机 API（如 /try-on、/chatkit）被误送远程代理。

# 单次用户消息内智能体多轮工具调用上限（默认 100，范围 10–200）；复杂试穿/多图易触顶时可再提高
# CHATKIT_MAX_TURNS=120
#
# ChatKit / OpenAI Agents 调试：打印每轮 turn、工具名与参数、工具返回；并摘要 ChatKit 流事件（非逐字 delta）
# CHATKIT_AGENT_DEBUG=1
#
# CLIP / 向量检索（出现 SSLEOFError、UNEXPECTED_EOF_WHILE_READING 时二选一或组合尝试）：
# 1) 国内/直连 HF 不稳定：使用镜像
# HF_ENDPOINT=https://hf-mirror.com
# 2) 本机系统/Clash/v2ray 代理导致访问 huggingface.co TLS 被截断：让 HF 请求不走代理
# HF_BYPASS_PROXY_FOR_HUB=1
# 3) 自动多候选（懒加载 CLIP 时依次尝试；可与 HF_ENDPOINT 组合）
# HF_ENDPOINT_FALLBACKS=https://hf-mirror.com,https://huggingface.co
# 未设置 HF_ENDPOINT 时默认先镜像后官方（与旧版顺序相反）；若你希望先官方：
# HF_HUB_TRY_ORDER=official_first
# huggingface_hub 内部 http_backoff 默认会重试 5 次较慢；可缩短（默认已 patch 为 2）：
# HF_HUB_HTTP_MAX_RETRIES=2

# ChatKit 线程存储：sqlite（默认，进程重启保留）或 memory（仅内存）
# CHATKIT_STORE=sqlite
# SQLite 路径（默认 backend 工作目录下 data/chatkit_store.db）
# CHATKIT_SQLITE_PATH=data/chatkit_store.db

# --- 虚拟试穿 / 图像编辑（DashScope，默认 qwen-image-2.0-pro）---
# QWEN_IMAGE_EDIT_MODEL=qwen-image-2.0-pro
# QWEN_IMAGE_EDIT_REGION=singapore

# Qwen 因内容审核等失败时，用 xAI Grok Imagine（/v1/images/edits）重试（需 XAI_API_KEY）
# TRYON_XAI_FALLBACK=true
# TRYON_XAI_IMAGINE_MODEL=grok-imagine-image
# TRYON_XAI_RESOLUTION=2k
# 任意 QwenImageEditError 都走 xAI（调试用，易增加费用）
# TRYON_XAI_FALLBACK_ON_ANY_QWEN_ERROR=false
