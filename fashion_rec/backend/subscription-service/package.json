{
  "name": "fashion-rec-subscription-service",
  "version": "1.0.0",
  "type": "module",
  "description": "Creem.io subscription service using Hono",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate": "tsx src/migrate-period-end.ts",
    "migrate:fill": "tsx src/migrate-fill-period-end.ts"
  },
  "dependencies": {
    "creem_io": "^0.4.0",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.8.0",
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
