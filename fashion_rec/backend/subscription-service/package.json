{
  "name": "fashion-rec-subscription-service",
  "version": "1.0.0",
  "type": "module",
  "description": "Creem.io subscription service using Hono",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit",
    "card-keys:txt": "node scripts/generate-card-key-txt.mjs",
    "migrate": "tsx src/migrate-period-end.ts",
    "migrate:fill": "tsx src/migrate-fill-period-end.ts",
    "test:customers": "tsx test-customers.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "iceberg-js": "^0.8.1",
    "creem_io": "^1.1.0",
    "hono": "^4.12.19"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260519.1",
    "@types/node": "^25.9.0",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.92.0"
  }
}
