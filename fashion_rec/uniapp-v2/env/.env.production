# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'production'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = true
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = false

# 后台请求地址 (Fashion Rec API)
VITE_SERVER_BASEURL = 'https://fashion-rec.com'
VITE_API_URL = 'https://fashion-rec.com'

# Supabase
VITE_SUPABASE_URL = 'https://eufhccrelpucppognlym.supabase.co'
VITE_FALLBACK_LOCALE = auto
