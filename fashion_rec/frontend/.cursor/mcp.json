{
  "mcpServers": {
    "shadcnVue": {
      "command": "npx",
      "args": [
        "shadcn-vue@latest",
        "mcp"
      ],
      "env": {
        "HTTP_PROXY": "http://127.0.0.1:10808",
        "HTTPS_PROXY": "http://127.0.0.1:10808",
        "http_proxy": "http://127.0.0.1:10808",
        "https_proxy": "http://127.0.0.1:10808"
      }
    },
    "ai-elements-vue": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://registry.ai-elements-vue.com/mcp"
      ]
    }
  }
}
