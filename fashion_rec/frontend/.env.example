# API（与 shared getApiUrl 一致；本地后端见 backend/run.py 端口）
# VITE_API_URL=http://127.0.0.1:8001

# ChatKit API：开发环境若不设置，默认走同源 `/chatkit`（由 Vite 代理到 CHATKIT_API_BASE）。
# 生产构建未设置时，默认 `${VITE_API_URL}/chatkit`。
# 附件直传：`POST ${同上}/upload`、图片预览 `GET .../attachments/{id}/preview`（后端已实现）。
# VITE_CHATKIT_API_URL=/chatkit

# Supabase Auth（经 Cloudflare Router /supabase 代理，国内可达）
# VITE_SUPABASE_URL=https://fashion-rec.com/supabase
# VITE_SUPABASE_KEY=your-anon-key
# Web Google Sign-In
# VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# 代理 /chatkit 的目标后端（默认与 backend/run.py 的 uvicorn 端口一致：8001）
# CHATKIT_API_BASE=http://127.0.0.1:8001

# 域名校验 key（与 OpenAI 域名允许列表一致；starter 使用 VITE_CHATKIT_API_DOMAIN_KEY）
# VITE_CHATKIT_API_DOMAIN_KEY=domain_pk_localhost_dev
# VITE_CHATKIT_DOMAIN_KEY=local-dev
