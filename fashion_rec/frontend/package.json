{
  "name": "fashion-rec-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vue-tsc --noEmit && vite-ssg build",
    "build:spa": "vue-tsc --noEmit && vite build",
